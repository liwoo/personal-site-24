---
import Button from '~/components/ui/Button.astro';
import type { Link } from '~/types';
import { Icon } from 'astro-icon/components';

export interface Props {
  id?: string;
  name?: string;
  title?: string;
  tagline?: string;
  socialLinks?: Array<Link>;
  description?: string;
  actions?: Array<{ variant: 'primary'; target: '_blank'; text: 'Hire me'; href: '/' }>;
}

const { id, title, name, socialLinks = [], description = Astro.slots.render('description') } = Astro.props;
const heroBg = 'https://pub-a0f6f56fff3c42b9bb30bd2143c99754.r2.dev/web-hero.m4v';
---

<section class="not-prose relative flex flex-col justify-end h-[75lvh]">
  <!-- Background: static image fallback if video fails -->
  <div
    class="absolute inset-0 bg-[url(https://minio-api.dartsmw.com/chienda.com/setup.jpg)] bg-no-repeat bg-cover bg-center"
  >
  </div>

  <div class="absolute inset-0 pointer-events-none crt-scanlines grunge-overlay" aria-hidden="true">
    <video autoplay muted loop playsinline id="hero-video" class="h-[75lvh] w-full object-cover">
      <source src={heroBg} type="video/mp4" />
    </video>
    <div
      class="absolute h-[75lvh] inset-0 bg-gradient-to-b from-orange-200 via-orange-100 to-amber-100 dark:from-teal-300 dark:to-teal-950 mix-blend-hue dark:mix-blend-multiply"
    >
    </div>
  </div>
  <!-- absolute side bar right solid background -->
  <div
    class="absolute flex flex-col justify-end md:justify-center items-center gap-y-4 inset-y-0 right-0 w-full md:w-2/3 lg:w-1/2 xl:w-1/3 pb-8 md:pb-0"
  >
    <div id="hero-card" class="relative bg-white/90 dark:bg-[#1a1a1a]/95 backdrop-blur-xl backdrop-saturate-150 border border-gray-300/40 dark:border-gray-600/30 mx-4 md:ml-20 lg:m-0 text-base md:text-lg shadow-lg overflow-hidden">
      <!-- Invisible sizer — reserves height per viewport -->
      <div class="p-6 md:p-8 invisible font-semibold" aria-hidden="true">
        <span class="md:hidden">&gt; I build AI agents that go past the demo stage.</span>
        <span class="hidden md:inline">&gt; Hi, I'm Jeremiah. I build AI agents that go past the demo stage. Let's connect if that sort of thing interests you</span>
      </div>
      <!-- Visible typewriter — positioned over sizer -->
      <div class="absolute inset-0 p-6 md:p-8 font-semibold text-gray-900 dark:text-gray-100">
        <span class="text-sm text-primary font-bold">&gt;</span> <span id="typewriter-out"></span><span class="blink-cursor text-primary">_</span>
      </div>
    </div>
    <div id="hero-cta" class="flex gap-x-4 opacity-0 transition-opacity duration-500">
      <Button href="/about" variant="primary">Find_out_More</Button>
    </div>
  </div>

</section>

<!-- Lower third — sits on page bg below the video -->
<div class="bg-page">
  <div class="container py-8">
    <h2 class="text-2xl font-semibold uppercase tracking-tight text-default" set:text={name} />
    <h3 class="uppercase text-muted" set:text={title} />
    {
      socialLinks?.length ? (
        <ul class="flex mt-2 mb-4 md:order-1 md:mb-0 rtl:ml-0 rtl:-mr-2 rtl:md:ml-0 rtl:md:mr-4 justify-start">
          {socialLinks.map(({ ariaLabel, href, text, icon }) => (
            <li>
              <a
                class="text-muted hover:text-primary focus:outline-none text-sm p-2.5 inline-flex items-center transition-colors"
                aria-label={ariaLabel}
                href={href}
              >
                {icon && <Icon name={icon} class="w-5 h-5" />}
                <Fragment set:html={text} />
              </a>
            </li>
          ))}
        </ul>
      ) : (
        ''
      )
    }
  </div>
</div>

<script>
  // Force video restart on every page load
  document.addEventListener('astro:page-load', () => {
    const video = document.getElementById('hero-video') as HTMLVideoElement;
    if (video) {
      // Force reload the video source to ensure it plays
      const source = video.querySelector('source');
      const currentSrc = source?.src;

      if (currentSrc) {
        video.load(); // Reload video element
        video.currentTime = 0;

        // Use setTimeout to ensure the video starts after the page transition
        setTimeout(() => {
          video.play().catch((err) => console.log('Video autoplay failed:', err));
        }, 100);
      }
    }
  });

  // Handle tab visibility changes
  document.addEventListener('visibilitychange', () => {
    const video = document.getElementById('hero-video') as HTMLVideoElement;
    if (video) {
      if (document.hidden) {
        video.pause();
      } else {
        video.currentTime = 0;
        video.play().catch((err) => console.log('Video autoplay failed:', err));
      }
    }
  });

  // Fallback for initial page load
  window.addEventListener('load', () => {
    const video = document.getElementById('hero-video') as HTMLVideoElement;
    if (video && video.paused) {
      video.play().catch((err) => console.log('Video autoplay failed on load:', err));
    }
  });

  // Typewriter effect with inline styling for key phrases
  function initTypewriter() {
    const outEl = document.getElementById('typewriter-out');
    const ctaEl = document.getElementById('hero-cta');
    if (!outEl || !ctaEl) return;

    const isMobile = window.innerWidth < 768;
    // Define segments: plain text or styled spans
    const segments = isMobile
      ? [
          { text: 'I build ' },
          { text: 'AI agents', cls: 'underlined' },
          { text: ' that go past the demo stage.' },
        ]
      : [
          { text: "Hi, I'm Jeremiah. I build " },
          { text: 'AI agents', cls: 'underlined' },
          { text: " that go past the demo stage. Let's connect if that sort of thing interests you" },
        ];

    let segIdx = 0;
    let charIdx = 0;
    outEl.innerHTML = '';
    ctaEl.style.opacity = '0';

    // Pre-create span elements for each segment
    const spanEls: HTMLSpanElement[] = segments.map(seg => {
      const span = document.createElement('span');
      if (seg.cls) span.className = seg.cls;
      outEl.appendChild(span);
      return span;
    });

    function type() {
      if (segIdx >= segments.length) {
        ctaEl.style.opacity = '1';
        return;
      }
      const seg = segments[segIdx];
      const span = spanEls[segIdx];

      if (charIdx < seg.text.length) {
        span.textContent = seg.text.slice(0, charIdx + 1);
        charIdx++;
        setTimeout(type, 35 + Math.random() * 25);
      } else {
        segIdx++;
        charIdx = 0;
        type();
      }
    }

    setTimeout(type, 800);
  }

  document.addEventListener('astro:page-load', initTypewriter);
  initTypewriter();
</script>
