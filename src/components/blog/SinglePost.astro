---
import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';
import SocialShare from '~/components/common/SocialShare.astro';
import { Icon } from 'astro-icon/components';

import type { Post } from '~/types';
import Bio from '../widgets/Bio.astro';
import SignupForm from '../widgets/SignupForm.astro';
import Related from './Related.astro';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
const { Content } = post;
---

<section class="py-8 lg:py-12 mx-auto">
  <article>
    <header class={`post-header ${post.image ? '' : ''}`}>
      {
        post.image ? (
          <div class="crt-scanlines max-w-full lg:max-w-[900px] mx-auto mb-6">
            <Image
              src={post.image}
              class="w-full bg-gray-400 dark:bg-slate-700 border border-gray-500/20"
              widths={[400, 900]}
              sizes="(max-width: 900px) 400px, 900px"
              alt={post?.excerpt || ''}
              width={900}
              height={506}
              loading="eager"
              decoding="async"
            />
          </div>
        ) : (
          <div class="max-w-3xl mx-auto px-4 sm:px-6">
            <div class="accent-bar-strong" />
          </div>
        )
      }
    </header>
    <div
      class="post-meta mx-auto px-6 sm:px-6 max-w-3xl w-2/3 md:w-1/2 mt-8 flex justify-between flex-col items-center sm:flex-row z-20 sticky top-0 lg:top-10 bg-card/80 py-4 lg:py-2 backdrop-blur-xl border border-gray-500/20"
    >
      <PostTags tags={post.tags} class="hidden lg:block mr-5 rtl:mr-0 rtl:ml-5" />
      <SocialShare
        url={url}
        text={post.title}
        class="mt-5 sm:mt-1 align-middle flex justify-center items-center text-default"
      />
    </div>
    <div
      class="post-content drop-cap container-article prose prose-lg lg:prose-xl code-block prose-pre:pt-12 prose-pre:border prose-pre:border-gray-500/20 dark:prose-invert prose-headings:text-primary prose-img:w-full prose-img:border prose-img:border-gray-500/20 prose-img:hover:border-primary prose-md prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-primary prose-a:underline-offset-4 mt-8 prose-headings:scroll-mt-[80px] prose-blockquote:bg-card prose-blockquote:p-4 prose-blockquote:border-primary/50 prose-h3:text-default prose-h4:text-muted prose-hr:border-primary/20"
    >
      {Content ? <Content /> : <Fragment set:html={post.content || ''} />}
    </div>
    <div class="post-footer container-article">
      <div class="my-8 lg:w-1/2">
        <!--Discuss on X Button-->
        {post.commentLink && (
          <a href={post.commentLink} class="btn flex gap-x-3 items-center">
            Discuss on <Icon name="tabler:brand-x" class="w-5 h-5" />
          </a>
        )}
      </div>
      <PostTags tags={post.tags} class="lg:hidden mr-5 my-4 rtl:mr-0 rtl:ml-5" />
    </div>
    <div class="post-bio">
      <Bio />
    </div>
    <div class="post-extras container-lg">
      <SignupForm />

      <Related tags={post.tags} postId={post.id} />
    </div>
  </article>
</section>

<style>
  .post-header {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .post-header.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .post-meta {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out 0.2s, transform 0.6s ease-out 0.2s;
  }

  .post-meta.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .post-content {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease-out 0.3s, transform 0.8s ease-out 0.3s;
  }

  .post-content.animate-in {
    opacity: 1;
    transform: translateY(0);
  }

  .post-footer,
  .post-bio,
  .post-extras {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .post-footer.is-visible,
  .post-bio.is-visible,
  .post-extras.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Markdown content animations */
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4),
  .post-content :global(h5),
  .post-content :global(h6) {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .post-content :global(h2.is-visible),
  .post-content :global(h3.is-visible),
  .post-content :global(h4.is-visible),
  .post-content :global(h5.is-visible),
  .post-content :global(h6.is-visible) {
    opacity: 1;
    transform: translateY(0);
  }

  .post-content :global(p),
  .post-content :global(ul),
  .post-content :global(ol),
  .post-content :global(blockquote) {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }

  .post-content :global(p.is-visible),
  .post-content :global(ul.is-visible),
  .post-content :global(ol.is-visible),
  .post-content :global(blockquote.is-visible) {
    opacity: 1;
    transform: translateY(0);
  }

  .post-content :global(pre),
  .post-content :global(img),
  .post-content :global(video) {
    opacity: 0;
    transform: scale(0.98);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .post-content :global(pre.is-visible),
  .post-content :global(img.is-visible),
  .post-content :global(video.is-visible) {
    opacity: 1;
    transform: scale(1);
  }
</style>

<script>
  const initPostAnimations = () => {
    // Immediate animations for header, meta, and content
    const postHeader = document.querySelector('.post-header');
    const postMeta = document.querySelector('.post-meta');
    const postContent = document.querySelector('.post-content');

    setTimeout(() => {
      postHeader?.classList.add('animate-in');
      postMeta?.classList.add('animate-in');
      postContent?.classList.add('animate-in');
    }, 150);

    // Scroll-based animations for footer and extras
    const observerCallback = (entries: IntersectionObserverEntry[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    };

    const observerOptions = {
      threshold: 0.15,
      rootMargin: '0px 0px -50px 0px',
    };

    const observer = new IntersectionObserver(observerCallback, observerOptions);

    // Observe footer, bio, and extras
    const scrollElements = document.querySelectorAll('.post-footer, .post-bio, .post-extras');
    scrollElements.forEach((element) => observer.observe(element));

    // Observe markdown elements within post-content
    const markdownElements = document.querySelectorAll(
      '.post-content h2, .post-content h3, .post-content h4, .post-content h5, .post-content h6, ' +
      '.post-content p, .post-content ul, .post-content ol, .post-content blockquote, ' +
      '.post-content pre, .post-content img, .post-content video'
    );
    markdownElements.forEach((element) => observer.observe(element));
  };

  // Extract syntax-highlighted tokens from Shiki DOM
  type Token = { text: string; color: string };
  type TokenLine = Token[];

  function extractHighlightedLines(preEl: HTMLPreElement): TokenLine[] {
    const isDark = document.documentElement.classList.contains('dark');
    const defaultColor = isDark ? '#e1e4e8' : '#24292e';
    const lines: TokenLine[] = [];

    const lineEls = preEl.querySelectorAll('.line');
    if (lineEls.length === 0) {
      // Fallback: plain text
      const text = preEl.textContent || '';
      return text.split('\n').map(line => [{ text: line, color: defaultColor }]);
    }

    lineEls.forEach(lineEl => {
      const tokens: Token[] = [];
      const spans = lineEl.querySelectorAll('span');
      if (spans.length === 0) {
        tokens.push({ text: lineEl.textContent || '', color: defaultColor });
      } else {
        spans.forEach(span => {
          const style = span.getAttribute('style') || '';
          let color = defaultColor;
          if (isDark) {
            const darkMatch = style.match(/--shiki-dark:\s*(#[0-9a-fA-F]+)/);
            if (darkMatch) color = darkMatch[1];
          } else {
            const lightMatch = style.match(/(?:^|;)\s*color:\s*(#[0-9a-fA-F]+)/);
            if (lightMatch) color = lightMatch[1];
          }
          const text = span.textContent || '';
          if (text) tokens.push({ text, color });
        });
      }
      lines.push(tokens);
    });

    // Trim trailing empty lines
    while (lines.length > 0 && lines[lines.length - 1].every(t => t.text.trim() === '')) {
      lines.pop();
    }
    return lines;
  }

  // Render code snippet to a branded PNG via Canvas with syntax highlighting
  function renderCodeImage(preEl: HTMLPreElement, langLabel: string): Promise<Blob> {
    return new Promise((resolve, reject) => {
      const scale = 2;
      const padding = 40 * scale;
      const lineHeight = 18 * scale;
      const fontSize = 13 * scale;
      const headerHeight = 36 * scale;
      const footerHeight = 32 * scale;
      const charW = fontSize * 0.6;
      const maxLineChars = 72;
      const lineNumWidth = 4 * charW;
      const codeX = padding * 0.4 + lineNumWidth;

      const highlightedLines = extractHighlightedLines(preEl);

      const codeHeight = highlightedLines.length * lineHeight + padding;
      const canvasW = maxLineChars * charW + codeX + padding;
      const canvasH = headerHeight + codeHeight + footerHeight + padding;

      const canvas = document.createElement('canvas');
      canvas.width = canvasW;
      canvas.height = canvasH;
      const ctx = canvas.getContext('2d');
      if (!ctx) return reject(new Error('No canvas context'));

      const isDark = document.documentElement.classList.contains('dark');
      const bg = isDark ? '#1a1a1a' : '#fafafa';
      const codeBg = isDark ? '#24292e' : '#ffffff';
      const mutedColor = isDark ? 'rgba(255,255,255,0.3)' : 'rgba(0,0,0,0.25)';
      const accentColor = '#d89121';
      const fontStack = '"Space Mono", "Courier New", monospace';

      // Background
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, canvasW, canvasH);

      // Header bar
      ctx.fillStyle = accentColor;
      ctx.fillRect(0, 0, canvasW, headerHeight);
      ctx.fillStyle = '#000';
      ctx.font = `bold ${11 * scale}px ${fontStack}`;
      ctx.textBaseline = 'middle';
      ctx.fillText(`> ${langLabel}_`, padding * 0.6, headerHeight / 2);
      const siteText = 'chienda.com';
      const siteWidth = ctx.measureText(siteText).width;
      ctx.fillText(siteText, canvasW - padding * 0.6 - siteWidth, headerHeight / 2);

      // Code area
      const codeY = headerHeight;
      ctx.fillStyle = codeBg;
      ctx.fillRect(0, codeY, canvasW, codeHeight);

      // Subtle border
      ctx.strokeStyle = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.08)';
      ctx.lineWidth = 1 * scale;
      ctx.strokeRect(0, codeY, canvasW, codeHeight);

      // Line number gutter separator
      ctx.strokeStyle = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
      ctx.beginPath();
      ctx.moveTo(codeX - charW * 0.5, codeY);
      ctx.lineTo(codeX - charW * 0.5, codeY + codeHeight);
      ctx.stroke();

      // Render each line with syntax colors
      ctx.font = `${fontSize}px ${fontStack}`;
      ctx.textBaseline = 'top';

      for (let i = 0; i < highlightedLines.length; i++) {
        const y = codeY + padding * 0.5 + i * lineHeight;

        // Line number
        const lineNum = String(i + 1).padStart(3, ' ');
        ctx.fillStyle = mutedColor;
        ctx.fillText(lineNum, padding * 0.4, y);

        // Tokens with syntax colors
        let x = codeX;
        for (const token of highlightedLines[i]) {
          ctx.fillStyle = token.color;
          ctx.fillText(token.text, x, y);
          x += ctx.measureText(token.text).width;
        }
      }

      // Footer
      const footerY = codeY + codeHeight;
      ctx.fillStyle = bg;
      ctx.fillRect(0, footerY, canvasW, footerHeight + padding);

      ctx.fillStyle = mutedColor;
      ctx.font = `${10 * scale}px ${fontStack}`;
      ctx.textBaseline = 'top';
      ctx.fillText(`>_ chienda.com  ·  ${window.location.pathname}`, padding * 0.6, footerY + 10 * scale);

      // Bottom accent line
      ctx.fillStyle = accentColor;
      ctx.fillRect(0, canvasH - 3 * scale, canvasW, 3 * scale);

      canvas.toBlob((blob) => {
        if (blob) resolve(blob);
        else reject(new Error('Failed to create blob'));
      }, 'image/png');
    });
  }

  // Code block toolbar: language label, copy, share
  function initCodeToolbars() {
    const langMap: Record<string, string> = {
      python: 'Python', py: 'Python', javascript: 'JavaScript', js: 'JavaScript',
      typescript: 'TypeScript', ts: 'TypeScript', json: 'JSON', bash: 'Bash',
      shell: 'Shell', sql: 'SQL', html: 'HTML', css: 'CSS', yaml: 'YAML',
      yml: 'YAML', rust: 'Rust', go: 'Go', java: 'Java', csharp: 'C#',
      cs: 'C#', cpp: 'C++', c: 'C', ruby: 'Ruby', php: 'PHP', swift: 'Swift',
      kotlin: 'Kotlin', dart: 'Dart', jsx: 'JSX', tsx: 'TSX', mdx: 'MDX',
      xml: 'XML', toml: 'TOML', ini: 'INI', dockerfile: 'Dockerfile',
      graphql: 'GraphQL', r: 'R', lua: 'Lua', scala: 'Scala',
      plaintext: 'Output', text: 'Output',
    };

    document.querySelectorAll('.code-block pre').forEach((pre) => {
      if (pre.querySelector('.code-toolbar')) return;

      const langKey = pre.getAttribute('data-language') || '';
      const langLabel = langMap[langKey] || (langKey ? langKey.toUpperCase() : 'CODE');
      const code = pre.querySelector('code');
      const codeText = code?.textContent || pre.textContent || '';

      const toolbar = document.createElement('div');
      toolbar.className = 'code-toolbar';
      toolbar.innerHTML = `
        <span class="code-lang">&gt; ${langLabel}_</span>
        <span class="code-actions">
          <button class="code-copy-btn" aria-label="Copy code">COPY</button>
          <button class="code-share-btn" aria-label="Share snippet">SHARE</button>
        </span>
      `;
      pre.insertBefore(toolbar, pre.firstChild);

      // Copy
      toolbar.querySelector('.code-copy-btn')!.addEventListener('click', async () => {
        const btn = toolbar.querySelector('.code-copy-btn') as HTMLButtonElement;
        try {
          await navigator.clipboard.writeText(codeText);
          btn.textContent = 'COPIED';
          setTimeout(() => btn.textContent = 'COPY', 2000);
        } catch {
          btn.textContent = 'FAILED';
          setTimeout(() => btn.textContent = 'COPY', 2000);
        }
      });

      // Share — render to canvas image
      toolbar.querySelector('.code-share-btn')!.addEventListener('click', async () => {
        const btn = toolbar.querySelector('.code-share-btn') as HTMLButtonElement;
        btn.textContent = '...';

        try {
          const blob = await renderCodeImage(pre as HTMLPreElement, langLabel);

          // Mobile: native share with image file
          if (navigator.share && /Mobi|Android/i.test(navigator.userAgent)) {
            const file = new File([blob], `snippet-${langKey || 'code'}.png`, { type: 'image/png' });
            if (navigator.canShare?.({ files: [file] })) {
              await navigator.share({
                files: [file],
                title: `${langLabel} snippet from chienda.com`,
                url: window.location.href,
              });
              btn.textContent = 'SHARE';
              return;
            }
          }

          // Desktop: download the image
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = `snippet-${langKey || 'code'}.png`;
          a.click();
          URL.revokeObjectURL(url);
          btn.textContent = 'SAVED';
          setTimeout(() => btn.textContent = 'SHARE', 2000);
        } catch {
          btn.textContent = 'FAILED';
          setTimeout(() => btn.textContent = 'SHARE', 2000);
        }
      });
    });
  }

  // Initial load
  window.addEventListener('load', () => {
    initPostAnimations();
    initCodeToolbars();
  });

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', () => {
    initPostAnimations();
    initCodeToolbars();
  });
</script>
